# Without DATABASE_URL the site runs status-checks only; without SMTP_* no emails are sent.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# Public base URL used to build unsubscribe links in emails.
BASE_URL=http://localhost:8000

HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

POLL_INTERVAL_MINUTES=5
HTTP_TIMEOUT_SECONDS=20

# Gmail needs an App Password, not your account password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-address@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-address@gmail.com
SMTP_FROM_NAME=CUNY Seat Tracker

# 587 = STARTTLS; for implicit TLS use 465 with SMTP_USE_SSL=true.
SMTP_USE_SSL=false
SMTP_STARTTLS=true
